# ============================================
# BDS STORE VPN Backend - Environment Variables
# ============================================
# Copy this file to .env and fill in your values
# ဤဖိုင်ကို .env သို့ ကူးပြီး သင့်တန်ဖိုးများကို ဖြည့်ပါ

# --- Server Configuration ---
# Port the Express server will listen on
PORT=3000

# Environment: development | production | test
NODE_ENV=development

# --- PostgreSQL Database Configuration ---
# Database host (use 'db' for Docker, 'localhost' for local dev)
DB_HOST=localhost

# Database port (default PostgreSQL port: 5432)
DB_PORT=5432

# Database name
DB_NAME=bds_store_vpn

# Database username
DB_USER=postgres

# Database password
DB_PASSWORD=your_secure_password_here

# --- JWT Authentication ---
# Secret key for signing JWT tokens (use a long random string)
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production

# JWT token expiration duration (e.g., 7d, 24h, 30d)
JWT_EXPIRES_IN=7d

# --- AdMob Reward Configuration ---
# How many hours of VPN time a user gets per ad watched
# ကြော်ငြာတစ်ခုကြည့်လျှင် VPN အချိန် ဘယ်နှစ်နာရီရမည်
ADMOB_REWARD_DURATION_HOURS=2

# Google AdMob SSV key server URL (for verifying ad reward callbacks)
GOOGLE_ADMOB_KEY_SERVER_URL=https://www.gstatic.com/admob/reward/verifier-keys.json

# --- 3x-ui (Xray Core) Panel Configuration ---
# Full URL of your 3x-ui panel (include port if non-standard)
# သင့် 3x-ui panel ၏ URL
XUI_PANEL_URL=http://your-server-ip:2053

# 3x-ui panel admin username
XUI_USERNAME=admin

# 3x-ui panel admin password
XUI_PASSWORD=admin_password_here

# Default inbound ID to add clients to (found in 3x-ui panel)
XUI_DEFAULT_INBOUND_ID=1

# --- Rate Limiting ---
# Max requests per window for general endpoints
RATE_LIMIT_GENERAL=100

# Max requests per window for auth endpoints
RATE_LIMIT_AUTH=5

# Max requests per window for ad verification endpoints
RATE_LIMIT_ADS=10

# Rate limit window in minutes
RATE_LIMIT_WINDOW_MINUTES=15

# --- Logging ---
# Log level: error, warn, info, http, verbose, debug, silly
LOG_LEVEL=debug
